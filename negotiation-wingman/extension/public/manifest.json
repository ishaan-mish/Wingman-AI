{
  "manifest_version": 3,
  "name": "Wingman AI",
  "version": "1.0",
  "action": {
    "default_popup": "index.html"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://meet.google.com/*","http://localhost:5000/*"],
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["src/content.jsx"]
    }
  ]
  
}
